# ============================================================
# LYFYE MARKETING STUDIO - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local for local development.
# Variables marked [REQUIRED] must be set or the app will not start.
# Variables marked [OPTIONAL] have defaults or enable optional features.
# ============================================================


# ============================================================
# DATABASE [REQUIRED]
# ============================================================

# Neon PostgreSQL connection string (pooled)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/marketing-studio-prod?sslmode=require"

# Direct connection for migrations (non-pooled)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/marketing-studio-prod?sslmode=require"


# ============================================================
# AUTHENTICATION [REQUIRED]
# ============================================================

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"

# NextAuth URL (must match deployment URL)
NEXTAUTH_URL="http://localhost:3000"

# Demo Mode: Set to "true" to bypass authentication
# Shows "Demo Mode" banner and uses demo user
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# Google OAuth (for user login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# [OPTIONAL] Microsoft Azure AD OAuth (for enterprise SSO)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""


# ============================================================
# AI PROVIDERS [REQUIRED - at least one]
# ============================================================

# Anthropic API key (primary AI provider for Mia)
# [REQUIRED] if using default Mia configuration
ANTHROPIC_API_KEY=""

# [OPTIONAL] OpenAI API key (fallback provider)
OPENAI_API_KEY=""

# [OPTIONAL] Google Gemini API key (secondary fallback)
GEMINI_API_KEY=""

# Default provider: "anthropic" or "openai"
AI_PROVIDER_DEFAULT="anthropic"

# Fallback provider when primary fails
AI_PROVIDER_FALLBACK="openai"


# ============================================================
# PUBLISHING - OAUTH CREDENTIALS
# ============================================================

# LinkedIn OAuth [OPTIONAL - required for LinkedIn publishing]
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://studio.lyfye.com/api/auth/callback/linkedin"

# X/Twitter OAuth [OPTIONAL - required for X/Twitter publishing]
X_CLIENT_ID=""
X_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_BEARER_TOKEN=""

# YouTube OAuth [OPTIONAL - required for YouTube publishing]
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="https://studio.lyfye.com/api/auth/callback/youtube"


# ============================================================
# VIDEO GENERATION [OPTIONAL]
# ============================================================

# Runway API key (for video generation)
RUNWAY_API_KEY=""

# [OPTIONAL] Sora API key (future fallback provider)
SORA_API_KEY=""

# ElevenLabs Voice Synthesis
ELEVENLABS_API_KEY=""

# HeyGen AI Avatars
HEYGEN_API_KEY=""

# Suno AI Music
SUNO_API_KEY=""


# ============================================================
# ASSET STORAGE [OPTIONAL]
# ============================================================

# Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=""


# ============================================================
# BACKGROUND JOBS [REQUIRED for publishing and video]
# ============================================================

# Inngest event key and signing key
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# [OPTIONAL] Inngest branch environment for preview deployments
INNGEST_BRANCH=""


# ============================================================
# DEPLOYMENT [REQUIRED for production]
# ============================================================

# Vercel deployment URL (set automatically by Vercel)
VERCEL_URL=""

# [OPTIONAL] Custom domain
NEXT_PUBLIC_APP_URL="https://studio.lyfye.com"


# ============================================================
# SEO ANALYSIS [OPTIONAL]
# ============================================================

SERPAPI_API_KEY=""


# ============================================================
# MONITORING [OPTIONAL but strongly recommended]
# ============================================================

# Sentry DSN for error tracking
SENTRY_DSN=""

# [OPTIONAL] Sentry auth token for source map uploads
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""


# ============================================================
# EMAIL [OPTIONAL]
# ============================================================

# Transactional email (for team invites, notifications)
RESEND_API_KEY=""
EMAIL_FROM="studio@lyfye.com"


# ============================================================
# FEATURE FLAGS [OPTIONAL]
# ============================================================

FEATURE_MOCK_CONNECTORS="true"
FEATURE_AI_TRANSFORMS="true"
FEATURE_ADVANCED_WORKFLOWS="false"
FEATURE_CRM_INTEGRATION="false"

# Enable BYOK (Bring Your Own Key) for AI providers
NEXT_PUBLIC_ENABLE_BYOK="false"

# Enable video generation feature
NEXT_PUBLIC_ENABLE_VIDEO="true"

# Enable analytics dashboard (stub)
NEXT_PUBLIC_ENABLE_ANALYTICS="false"


# ============================================================
# TELEMETRY [OPTIONAL]
# ============================================================

TELEMETRY_ENABLED="true"


# ============================================================
# NOTES
# ============================================================
# - Never commit real secrets to version control
# - Use Vercel Environment Variables for production
# - DEMO_MODE=true is useful for demos and testing
# - At minimum, you need: NEXTAUTH_SECRET + (DEMO_MODE=true OR OAuth provider)
